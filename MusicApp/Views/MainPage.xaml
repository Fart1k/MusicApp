<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MusicApp.ViewModels"
             x:Class="MusicApp.Views.MainPage"
             x:Name="Root">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Entry
            Placeholder="Title"
            Text="{Binding NewTitle}"/>

        <Entry
            Placeholder="Artist"
            Text="{Binding NewArtist}"/>

        <Button
            Text="Select MP3 File"
            Command="{Binding PickFileCommand}"/>

        <Button
            Text="Add Song"
            Command="{Binding AddCommand}"/>


        <CollectionView ItemsSource="{Binding Songs}">

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Frame 
                        Padding="10" 
                        Margin="5"
                        CornerRadius="12"
                        HasShadow="True"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">

                        <Grid ColumnDefinitions="*,Auto">

                            <VerticalStackLayout Grid.Column="0" Spacing="2">

                                <Label 
                                    Text="{Binding Title}"
                                    FontSize="18"
                                    FontAttributes="Bold"
                                    TextColor="{AppThemeBinding Light=Black, Dark=White}"/>

                                <Label 
                                    Text="{Binding Artist}"
                                    FontSize="14"
                                    Opacity="0.7"
                                    TextColor="{AppThemeBinding Light=Black, Dark=White}"/>

                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="5">

                                <HorizontalStackLayout Spacing="5">

                                    <Button 
                                        Text="▲"
                                        WidthRequest="40"
                                        Command="{Binding BindingContext.MoveUpCommand, Source={x:Reference Root}}"
                                        CommandParameter="{Binding}" />

                                    <Button 
                                        Text="▼"
                                        WidthRequest="40"
                                        Command="{Binding BindingContext.MoveDownCommand, Source={x:Reference Root}}"
                                        CommandParameter="{Binding}" />

                                </HorizontalStackLayout>

                                <Button 
                                    Text="Play"
                                    Command="{Binding BindingContext.PlayCommand, Source={x:Reference Root}}"
                                    CommandParameter="{Binding}" />

                                <Button 
                                    Text="Pause"
                                    Command="{Binding BindingContext.PauseCommand, Source={x:Reference Root}}" />   

                                <Button 
                                    Text="Delete"
                                    Command="{Binding BindingContext.DeleteCommand, Source={x:Reference Root}}"
                                    CommandParameter="{Binding}" />

                            </VerticalStackLayout>

                        </Grid>

                    </Frame>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </VerticalStackLayout>
    
</ContentPage>
