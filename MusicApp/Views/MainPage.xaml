<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MusicApp.ViewModels"
             x:Class="MusicApp.Views.MainPage"
             x:Name="Root">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Entry
            Placeholder="Title"
            Text="{Binding NewTitle}"/>

        <Entry
            Placeholder="Artist"
            Text="{Binding NewArtist}"/>

        <Button
            Text="Select MP3 File"
            Command="{Binding PickFileCommand}"/>

        <Button
            Text="Add Song"
            Command="{Binding AddCommand}"/>
        

        <CollectionView ItemsSource="{Binding Songs}">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid 
                        Padding="10"
                        ColumnDefinitions="*, Auto">

                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="{Binding Title}" FontSize="18" />
                            <Label Text="{Binding Artist}" FontSize="14"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1">

                            <Button
                                Text="Play"
                                Command="{Binding BindingContext.PlayCommand, Source={x:Reference Root}}"
                                CommandParameter="{Binding}"/>

                            <Button
                                Text="Pause"
                                Command="{Binding BindingContext.PauseCommand, Source={x:Reference Root}}"/>

                            <Button
                                Grid.Column="1"
                                Text="Delete"
                                Command="{Binding BindingContext.DeleteCommand, Source={x:Reference Name=Root}}"
                                CommandParameter="{Binding}"/>

                        </VerticalStackLayout>
                        
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            
        </CollectionView>
        
    </VerticalStackLayout>
    
</ContentPage>
